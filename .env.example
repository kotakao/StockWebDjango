# StockWebDjango 環境變數範本
# 複製為 .env 後填入實際值。.env 嚴禁提交（見 .gitignore）。

# Django 密鑰（正式環境務必改為隨機長字串）
SECRET_KEY=change-me-to-a-random-secret

# 允許的主機（逗號分隔）
ALLOWED_HOSTS=localhost,127.0.0.1

# 自有資料庫（PostgreSQL）連線字串
# 格式：postgres://使用者:密碼@主機:埠/資料庫名
DATABASE_URL=postgres://stockweb:stockweb@localhost:5432/stockweb

# Redis（快取／Celery broker & result）
REDIS_URL=redis://localhost:6379/0

# 自選股／持股頁對應的使用者：Discord 使用者 ID，對應 market.db watchlist/holdings 的 user_id
WATCHLIST_USER_ID=0

# market.db 路徑（StockDCBot 產出的 SQLite，唯讀——由連線層 query_only＋Router 保證）
# 宿主機 runserver：指向本機實體檔案（見 AGENT.md 本機路徑節）
MARKET_DB_PATH=D:/01 DevProgram/00 Self-Project/StockDCBot/data/market.db

# market.db 所在目錄，僅 compose 掛載用（掛目錄且可寫：WAL 讀取需在同目錄建 -wal/-shm
# 輔助檔，檔案掛載 :ro 與 WAL 不相容）；宿主機 runserver 仍用 MARKET_DB_PATH。
# 與 MARKET_DB_PATH 的目錄一致。
MARKET_DB_DIR=D:/01 DevProgram/00 Self-Project/StockDCBot/data

# 近期市場警示（D12）：StockDCBot 每日報告 JSON 目錄（純 JSON 讀取、唯讀）。
# 宿主機 runserver：指向 StockDCBot 的 reports/ 目錄；未設定或目錄不存在時功能優雅降級。
REPORTS_DIR=D:/01 DevProgram/00 Self-Project/StockDCBot/reports

# reports/ 所在目錄，僅 compose 以 :ro 掛載用（純 JSON 檔案讀取，無 WAL 問題）。
# 容器內 REPORTS_DIR 由 compose 覆寫為 /reports；宿主機 runserver 仍用上方 REPORTS_DIR。
REPORTS_HOST_DIR=D:/01 DevProgram/00 Self-Project/StockDCBot/reports

# 公司質化研究（D13）：My-TW-Coverage 本機 clone 目錄（import_company_research 匯入用）。
# 未設定時匯入指令須以 --source 指定；兩者皆缺則指令報錯退出。
RESEARCH_SOURCE_DIR=

# ---- 下列僅 docker compose 的 postgres 服務使用 ----
POSTGRES_USER=stockweb
POSTGRES_PASSWORD=stockweb
POSTGRES_DB=stockweb
